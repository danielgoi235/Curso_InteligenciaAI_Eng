# ═══════════════════════════════════════════════════════════════
# Plataforma: IA Aplicada à Engenharia
# .env.example — Configure com seus valores reais em produção
# ═══════════════════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ── JWT & AUTH ──────────────────────────────────────────────────
JWT_SECRET=dev_secret_change_in_production_min_64_chars
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@citadel.com.br
ADMIN_PASSWORD=Admin@2025!

# ── DATABASE ────────────────────────────────────────────────────
DB_PATH=./data/plataforma.db

# ── HOTMART (Pagamentos) ────────────────────────────────────────
HOTMART_WEBHOOK_TOKEN=seu_token_hotmart_aqui
HOTMART_PRODUCT_ID=seu_id_produto_hotmart

# ── STRIPE (Alternativo) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_seu_stripe_secret
STRIPE_PRICE_ID=price_seu_stripe_price
STRIPE_WEBHOOK_SECRET=whsec_seu_stripe_webhook_secret

# ── EMAIL (Nodemailer) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app_gmail
SMTP_FROM=noreply@citadel.com.br

# ── TWILIO (WhatsApp API) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=seu_account_sid
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_PHONE_NUMBER=+55XXXXXXXXXXX
WHATSAPP_GROUP_URL=https://chat.whatsapp.com/seu_grupo

# ── ZOOM (Encontros ao vivo) ────────────────────────────────────
ZOOM_CLIENT_ID=seu_zoom_client_id
ZOOM_CLIENT_SECRET=seu_zoom_client_secret
ZOOM_ACCOUNT_ID=seu_zoom_account_id

# ── LOGGING ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log
